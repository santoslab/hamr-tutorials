digraph microkit {
  compound=true;

  // Do not edit this file as it will be overwritten if HAMR codegen is rerun

  // protection domains
  graph [style=rounded]
  subgraph cluster_gen_gen_MON {
    label = "gen_gen_MON";
    gen_gen_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_gen_gen {
      label = "gen_gen";
      gen_gen_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_gen_gen_outstruct_queue_1 [label=outstruct_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_splitter_splitter_MON {
    label = "splitter_splitter_MON";
    splitter_splitter_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_splitter_splitter {
      label = "splitter_splitter";
      splitter_splitter_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_splitter_splitter_instruct_queue_1 [label=instruct_queue_1];
      pd_splitter_splitter_xfield_queue_1 [label=xfield_queue_1];
      pd_splitter_splitter_yfield_queue_1 [label=yfield_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_incx_incx_MON {
    label = "incx_incx_MON";
    incx_incx_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_incx_incx {
      label = "incx_incx";
      incx_incx_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_incx_incx_inxfield_queue_1 [label=inxfield_queue_1];
      pd_incx_incx_outxfield_queue_1 [label=outxfield_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_clampx_clampx_MON {
    label = "clampx_clampx_MON";
    clampx_clampx_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_clampx_clampx {
      label = "clampx_clampx";
      clampx_clampx_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_clampx_clampx_inxfield_queue_1 [label=inxfield_queue_1];
      pd_clampx_clampx_outxfield_queue_1 [label=outxfield_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_decy_decy_MON {
    label = "decy_decy_MON";
    decy_decy_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_decy_decy {
      label = "decy_decy";
      decy_decy_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_decy_decy_inyfield_queue_1 [label=inyfield_queue_1];
      pd_decy_decy_outyfield_queue_1 [label=outyfield_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_merger_merger_MON {
    label = "merger_merger_MON";
    merger_merger_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_merger_merger {
      label = "merger_merger";
      merger_merger_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_merger_merger_inxfield_queue_1 [label=inxfield_queue_1];
      pd_merger_merger_inyfield_queue_1 [label=inyfield_queue_1];
      pd_merger_merger_outstruct_queue_1 [label=outstruct_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_consume_consume_MON {
    label = "consume_consume_MON";
    consume_consume_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_consume_consume {
      label = "consume_consume";
      consume_consume_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_consume_consume_instruct_queue_1 [label=instruct_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_pacer {
    label = "pacer";
    pacer_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

  }

  // memory regions
  StructSplit_System_Instance_gen_gen_outstruct_1_Memory_Region;

  StructSplit_System_Instance_splitter_splitter_xfield_1_Memory_Region;

  StructSplit_System_Instance_splitter_splitter_yfield_1_Memory_Region;

  StructSplit_System_Instance_incx_incx_outxfield_1_Memory_Region;

  StructSplit_System_Instance_clampx_clampx_outxfield_1_Memory_Region;

  StructSplit_System_Instance_decy_decy_outyfield_1_Memory_Region;

  StructSplit_System_Instance_merger_merger_outstruct_1_Memory_Region;

  // channels
  pacer_INVIS -> gen_gen_MON_INVIS [lhead=cluster_gen_gen_MON, minlen=2, dir=both];
  gen_gen_MON_INVIS -> gen_gen_INVIS [lhead=cluster_gen_gen, minlen=2, dir=both];
  pacer_INVIS -> splitter_splitter_MON_INVIS [lhead=cluster_splitter_splitter_MON, minlen=2, dir=both];
  splitter_splitter_MON_INVIS -> splitter_splitter_INVIS [lhead=cluster_splitter_splitter, minlen=2, dir=both];
  pacer_INVIS -> incx_incx_MON_INVIS [lhead=cluster_incx_incx_MON, minlen=2, dir=both];
  incx_incx_MON_INVIS -> incx_incx_INVIS [lhead=cluster_incx_incx, minlen=2, dir=both];
  pacer_INVIS -> clampx_clampx_MON_INVIS [lhead=cluster_clampx_clampx_MON, minlen=2, dir=both];
  clampx_clampx_MON_INVIS -> clampx_clampx_INVIS [lhead=cluster_clampx_clampx, minlen=2, dir=both];
  pacer_INVIS -> decy_decy_MON_INVIS [lhead=cluster_decy_decy_MON, minlen=2, dir=both];
  decy_decy_MON_INVIS -> decy_decy_INVIS [lhead=cluster_decy_decy, minlen=2, dir=both];
  pacer_INVIS -> merger_merger_MON_INVIS [lhead=cluster_merger_merger_MON, minlen=2, dir=both];
  merger_merger_MON_INVIS -> merger_merger_INVIS [lhead=cluster_merger_merger, minlen=2, dir=both];
  pacer_INVIS -> consume_consume_MON_INVIS [lhead=cluster_consume_consume_MON, minlen=2, dir=both];
  consume_consume_MON_INVIS -> consume_consume_INVIS [lhead=cluster_consume_consume, minlen=2, dir=both];

  // shared memory mappings
  pd_gen_gen_outstruct_queue_1 -> StructSplit_System_Instance_gen_gen_outstruct_1_Memory_Region [dir=both, style=dashed];
  pd_splitter_splitter_instruct_queue_1 -> StructSplit_System_Instance_gen_gen_outstruct_1_Memory_Region [dir=back, style=dashed];
  pd_splitter_splitter_xfield_queue_1 -> StructSplit_System_Instance_splitter_splitter_xfield_1_Memory_Region [dir=both, style=dashed];
  pd_splitter_splitter_yfield_queue_1 -> StructSplit_System_Instance_splitter_splitter_yfield_1_Memory_Region [dir=both, style=dashed];
  pd_incx_incx_inxfield_queue_1 -> StructSplit_System_Instance_splitter_splitter_xfield_1_Memory_Region [dir=back, style=dashed];
  pd_incx_incx_outxfield_queue_1 -> StructSplit_System_Instance_incx_incx_outxfield_1_Memory_Region [dir=both, style=dashed];
  pd_clampx_clampx_inxfield_queue_1 -> StructSplit_System_Instance_incx_incx_outxfield_1_Memory_Region [dir=back, style=dashed];
  pd_clampx_clampx_outxfield_queue_1 -> StructSplit_System_Instance_clampx_clampx_outxfield_1_Memory_Region [dir=both, style=dashed];
  pd_decy_decy_inyfield_queue_1 -> StructSplit_System_Instance_splitter_splitter_yfield_1_Memory_Region [dir=back, style=dashed];
  pd_decy_decy_outyfield_queue_1 -> StructSplit_System_Instance_decy_decy_outyfield_1_Memory_Region [dir=both, style=dashed];
  pd_merger_merger_inxfield_queue_1 -> StructSplit_System_Instance_clampx_clampx_outxfield_1_Memory_Region [dir=back, style=dashed];
  pd_merger_merger_inyfield_queue_1 -> StructSplit_System_Instance_decy_decy_outyfield_1_Memory_Region [dir=back, style=dashed];
  pd_merger_merger_outstruct_queue_1 -> StructSplit_System_Instance_merger_merger_outstruct_1_Memory_Region [dir=both, style=dashed];
  pd_consume_consume_instruct_queue_1 -> StructSplit_System_Instance_merger_merger_outstruct_1_Memory_Region [dir=back, style=dashed];
}