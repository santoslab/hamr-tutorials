# Do not edit this file as it will be overwritten if HAMR codegen is rerun

# `make all` (or `make`) verifies the whole crate -- every property plus the
# shared, property-independent Commutativity VCs -- in one `cargo-verus
# verify`. `make <property>` runs `cargo-verus verify` on just that
# property's generated VCs (its vc_init / vc_sequential / vc_post_pre /
# vc_non_disabling modules).

ENV_VARS = RUSTC_BOOTSTRAP=1

CARGO_FLAGS = -Z build-std=core,alloc,compiler_builtins \
              -Z build-std-features=compiler-builtins-mem \
              --target aarch64-unknown-none

# verify the entire crate (every property plus the shared Commutativity VCs)
.PHONY: all
all:
	$(ENV_VARS) cargo-verus verify $(CARGO_FLAGS)

# Compile every crate WITHOUT verification so the dependency crates (vstd,
# data, the GUMBO library crates) are cached as Verus import libraries before
# any per-property `--verify-module` run -- that flag is otherwise forwarded
# to the dependency crates too and fails on a clean build (see header note).
.PHONY: warm-deps
warm-deps:
	$(ENV_VARS) cargo-verus verify $(CARGO_FLAGS) -- --no-verify

# verify only property 'gen_range_sanity'
.PHONY: gen_range_sanity
gen_range_sanity: warm-deps
	$(ENV_VARS) cargo-verus verify $(CARGO_FLAGS) -- --verify-module gen_range_sanity::vc_init --verify-module gen_range_sanity::vc_sequential --verify-module gen_range_sanity::vc_post_pre --verify-module gen_range_sanity::vc_non_disabling

# verify only property 'merged_in_consume_range'
.PHONY: merged_in_consume_range
merged_in_consume_range: warm-deps
	$(ENV_VARS) cargo-verus verify $(CARGO_FLAGS) -- --verify-module merged_in_consume_range::vc_init --verify-module merged_in_consume_range::vc_sequential --verify-module merged_in_consume_range::vc_post_pre --verify-module merged_in_consume_range::vc_non_disabling

# verify only property 'end_to_end_functional'
.PHONY: end_to_end_functional
end_to_end_functional: warm-deps
	$(ENV_VARS) cargo-verus verify $(CARGO_FLAGS) -- --verify-module end_to_end_functional::vc_init --verify-module end_to_end_functional::vc_sequential --verify-module end_to_end_functional::vc_post_pre --verify-module end_to_end_functional::vc_non_disabling

# verify only property 'consume_range_loop_invariant'
.PHONY: consume_range_loop_invariant
consume_range_loop_invariant: warm-deps
	$(ENV_VARS) cargo-verus verify $(CARGO_FLAGS) -- --verify-module consume_range_loop_invariant::vc_init --verify-module consume_range_loop_invariant::vc_sequential --verify-module consume_range_loop_invariant::vc_post_pre --verify-module consume_range_loop_invariant::vc_non_disabling

# verify only property 'y_stays_strictly_below_x'
.PHONY: y_stays_strictly_below_x
y_stays_strictly_below_x: warm-deps
	$(ENV_VARS) cargo-verus verify $(CARGO_FLAGS) -- --verify-module y_stays_strictly_below_x::vc_init --verify-module y_stays_strictly_below_x::vc_sequential --verify-module y_stays_strictly_below_x::vc_post_pre --verify-module y_stays_strictly_below_x::vc_non_disabling

.PHONY: clean
clean:
	cargo clean
