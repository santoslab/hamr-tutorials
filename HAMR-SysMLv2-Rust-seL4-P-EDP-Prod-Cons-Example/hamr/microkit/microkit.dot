digraph microkit {
  compound=true;

  // protection domains
  graph [style=rounded]
  subgraph cluster_prod_prod_MON {
    label = "prod_prod_MON";
    prod_prod_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_prod_prod {
      label = "prod_prod";
      prod_prod_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_prod_prod_output_queue_1 [label=output_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_cons_cons_MON {
    label = "cons_cons_MON";
    cons_cons_MON_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

    graph [style=rounded]
    subgraph cluster_cons_cons {
      label = "cons_cons";
      cons_cons_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

      pd_cons_cons_input_queue_1 [label=input_queue_1];
    }
  }

  graph [style=rounded]
  subgraph cluster_pacer {
    label = "pacer";
    pacer_INVIS [label="", style=invis, width=.5, height=.5, fixedsize=true]

  }

  // memory regions
  ProdCons_System_Instance_prod_prod_output_1_Memory_Region;

  // channels
  pacer_INVIS -> prod_prod_MON_INVIS [lhead=cluster_prod_prod_MON, minlen=2, dir=both];
  prod_prod_MON_INVIS -> prod_prod_INVIS [lhead=cluster_prod_prod, minlen=2, dir=both];
  pacer_INVIS -> cons_cons_MON_INVIS [lhead=cluster_cons_cons_MON, minlen=2, dir=both];
  cons_cons_MON_INVIS -> cons_cons_INVIS [lhead=cluster_cons_cons, minlen=2, dir=both];

  // shared memory mappings
  pd_prod_prod_output_queue_1 -> ProdCons_System_Instance_prod_prod_output_1_Memory_Region [dir=both, style=dashed];
  pd_cons_cons_input_queue_1 -> ProdCons_System_Instance_prod_prod_output_1_Memory_Region [dir=back, style=dashed];
}