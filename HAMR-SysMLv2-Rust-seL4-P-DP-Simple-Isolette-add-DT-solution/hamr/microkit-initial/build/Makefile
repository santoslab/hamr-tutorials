# Do not edit this file as it will be overwritten if codegen is rerun

MICROKIT_TOOL ?= $(MICROKIT_SDK)/bin/microkit

CFLAGS := -mcpu=$(CPU) \
	-mstrict-align \
	-ffreestanding \
	-nostdlib \
	-g3 \
	-O3 \
	-Wall -Wno-unused-function -Werror -Wno-unused-command-line-argument \
	-I$(MICROKIT_BOARD_DIR)/include \
	-target $(TARGET)

LDFLAGS := -L$(MICROKIT_BOARD_DIR)/lib
LIBS := --start-group -lmicrokit -Tmicrokit.ld --end-group

SYSTEM_FILE := $(TOP_DIR)/microkit.system
SCHEDULE_FILE := $(TOP_DIR)/microkit.schedule.xml

IMAGES := temp_sensor_temp_sensor.elf temp_sensor_temp_sensor_MON.elf operator_interface_operator_interface.elf operator_interface_operator_interface_MON.elf thermostat_thermostat.elf thermostat_thermostat_MON.elf heat_source_heat_source.elf heat_source_heat_source_MON.elf pacer.elf
IMAGE_FILE = loader.img
REPORT_FILE = report.txt

UTIL_OBJS = printf.o util.o

TYPES_DIR = $(TOP_DIR)/types
TYPE_OBJS := $(TOP_DIR)/build/sb_queue_Isolette_Data_Model_Temp_1.o $(TOP_DIR)/build/sb_queue_Isolette_Data_Model_Set_Points_1.o $(TOP_DIR)/build/sb_queue_Isolette_Data_Model_On_Off_1.o

# exporting TOP_TYPES_INCLUDE in case other makefiles need it
export TOP_TYPES_INCLUDE = -I$(TYPES_DIR)/include

TOP_INCLUDE = $(TOP_TYPES_INCLUDE) -I$(TOP_DIR)/util/include

all: $(IMAGE_FILE)
	CHECK_FLAGS_BOARD_MD5:=.board_cflags-$(shell echo -- ${CFLAGS} ${MICROKIT_BOARD} ${MICROKIT_CONFIG}| shasum | sed 's/ *-//')

${CHECK_FLAGS_BOARD_MD5}:
	-rm -f .board_cflags-*
	touch $@

%.o: ${TOP_DIR}/util/src/%.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ -I$(TOP_DIR)/util/include

$(TOP_DIR)/build/sb_queue_Isolette_Data_Model_Temp_1.o: $(TOP_DIR)/types/src/sb_queue_Isolette_Data_Model_Temp_1.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE)


$(TOP_DIR)/build/sb_queue_Isolette_Data_Model_Set_Points_1.o: $(TOP_DIR)/types/src/sb_queue_Isolette_Data_Model_Set_Points_1.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE)


$(TOP_DIR)/build/sb_queue_Isolette_Data_Model_On_Off_1.o: $(TOP_DIR)/types/src/sb_queue_Isolette_Data_Model_On_Off_1.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE)


# monitor
temp_sensor_temp_sensor_MON.o: $(TOP_DIR)/components/temp_sensor_temp_sensor/src/temp_sensor_temp_sensor_MON.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/temp_sensor_temp_sensor/include

# user code
temp_sensor_temp_sensor_rust:
	make -C ${CRATES_DIR}/temp_sensor_temp_sensor $(RUST_MAKE_TARGET)

temp_sensor_temp_sensor.o: $(TOP_DIR)/components/temp_sensor_temp_sensor/src/temp_sensor_temp_sensor.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/temp_sensor_temp_sensor/include

# monitor
operator_interface_operator_interface_MON.o: $(TOP_DIR)/components/operator_interface_operator_interface/src/operator_interface_operator_interface_MON.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/operator_interface_operator_interface/include

# user code
operator_interface_operator_interface_rust:
	make -C ${CRATES_DIR}/operator_interface_operator_interface $(RUST_MAKE_TARGET)

operator_interface_operator_interface.o: $(TOP_DIR)/components/operator_interface_operator_interface/src/operator_interface_operator_interface.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/operator_interface_operator_interface/include

# monitor
thermostat_thermostat_MON.o: $(TOP_DIR)/components/thermostat_thermostat/src/thermostat_thermostat_MON.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/thermostat_thermostat/include

# user code
thermostat_thermostat_rust:
	make -C ${CRATES_DIR}/thermostat_thermostat $(RUST_MAKE_TARGET)

thermostat_thermostat.o: $(TOP_DIR)/components/thermostat_thermostat/src/thermostat_thermostat.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/thermostat_thermostat/include

# monitor
heat_source_heat_source_MON.o: $(TOP_DIR)/components/heat_source_heat_source/src/heat_source_heat_source_MON.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/heat_source_heat_source/include

# user code
heat_source_heat_source_rust:
	make -C ${CRATES_DIR}/heat_source_heat_source $(RUST_MAKE_TARGET)

heat_source_heat_source.o: $(TOP_DIR)/components/heat_source_heat_source/src/heat_source_heat_source.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ $(TOP_INCLUDE) -I$(TOP_DIR)/components/heat_source_heat_source/include

pacer.o: $(TOP_DIR)/components/pacer/src/pacer.c Makefile
	$(CC) -c $(CFLAGS) $< -o $@ -I$(TOP_INCLUDE)

temp_sensor_temp_sensor_MON.elf: temp_sensor_temp_sensor_MON.o
	$(LD) $(LDFLAGS) $^ $(LIBS) -o $@

temp_sensor_temp_sensor.elf: $(UTIL_OBJS) $(TYPE_OBJS) temp_sensor_temp_sensor_rust temp_sensor_temp_sensor.o
	$(LD) $(LDFLAGS) -L ${CRATES_DIR}/temp_sensor_temp_sensor/target/aarch64-unknown-none/release $(filter %.o, $^) $(LIBS) -ltemp_sensor_temp_sensor -o $@

operator_interface_operator_interface_MON.elf: operator_interface_operator_interface_MON.o
	$(LD) $(LDFLAGS) $^ $(LIBS) -o $@

operator_interface_operator_interface.elf: $(UTIL_OBJS) $(TYPE_OBJS) operator_interface_operator_interface_rust operator_interface_operator_interface.o
	$(LD) $(LDFLAGS) -L ${CRATES_DIR}/operator_interface_operator_interface/target/aarch64-unknown-none/release $(filter %.o, $^) $(LIBS) -loperator_interface_operator_interface -o $@

thermostat_thermostat_MON.elf: thermostat_thermostat_MON.o
	$(LD) $(LDFLAGS) $^ $(LIBS) -o $@

thermostat_thermostat.elf: $(UTIL_OBJS) $(TYPE_OBJS) thermostat_thermostat_rust thermostat_thermostat.o
	$(LD) $(LDFLAGS) -L ${CRATES_DIR}/thermostat_thermostat/target/aarch64-unknown-none/release $(filter %.o, $^) $(LIBS) -lthermostat_thermostat -o $@

heat_source_heat_source_MON.elf: heat_source_heat_source_MON.o
	$(LD) $(LDFLAGS) $^ $(LIBS) -o $@

heat_source_heat_source.elf: $(UTIL_OBJS) $(TYPE_OBJS) heat_source_heat_source_rust heat_source_heat_source.o
	$(LD) $(LDFLAGS) -L ${CRATES_DIR}/heat_source_heat_source/target/aarch64-unknown-none/release $(filter %.o, $^) $(LIBS) -lheat_source_heat_source -o $@

pacer.elf: $(UTIL_OBJS) $(TYPE_OBJS) pacer.o
	$(LD) $(LDFLAGS) $^ $(LIBS) -o $@

$(IMAGE_FILE): $(IMAGES) $(SYSTEM_FILE)
	xmllint --xinclude $(SYSTEM_FILE) -o $(SYSTEM_FILE).merged
	$(MICROKIT_TOOL) $(SYSTEM_FILE).merged --search-path $(TOP_BUILD_DIR) --board $(MICROKIT_BOARD) --config $(MICROKIT_CONFIG) -o $(IMAGE_FILE) -r $(REPORT_FILE)


qemu: $(IMAGE_FILE)
	$(QEMU) -machine virt,virtualization=on \
			-cpu cortex-a53 \
			-serial mon:stdio \
			-device loader,file=$(IMAGE_FILE),addr=0x70000000,cpu-num=0 \
			-m size=2G \
			-nographic

clean::
	rm -f *.o

test:: 
	make -C ${CRATES_DIR}/temp_sensor_temp_sensor test
	make -C ${CRATES_DIR}/operator_interface_operator_interface test
	make -C ${CRATES_DIR}/thermostat_thermostat test
	make -C ${CRATES_DIR}/heat_source_heat_source test

clean:: 
	make -C ${CRATES_DIR}/temp_sensor_temp_sensor clean
	make -C ${CRATES_DIR}/operator_interface_operator_interface clean
	make -C ${CRATES_DIR}/thermostat_thermostat clean
	make -C ${CRATES_DIR}/heat_source_heat_source clean

verus: 
	make -C ${CRATES_DIR}/temp_sensor_temp_sensor verus
	make -C ${CRATES_DIR}/operator_interface_operator_interface verus
	make -C ${CRATES_DIR}/thermostat_thermostat verus
	make -C ${CRATES_DIR}/heat_source_heat_source verus
